# ==============================================
# SIMRS-SIMTECH Environment Configuration
# ==============================================
# Copy this file to .env and configure values

# ----------------------------------------------
# Frontend Configuration (Build-time for Vite)
# ----------------------------------------------
VITE_API_BASE_URL=http://localhost:5000/api

# ----------------------------------------------
# Backend Configuration
# ----------------------------------------------
PORT=5000
FRONTEND_URL=http://localhost:4173
JWT_SECRET=your_jwt_secret_here_change_in_production

# ----------------------------------------------
# Database Configuration
# ----------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=simrs_user
DB_PASSWORD=simrs_pass
DB_NAME=simrs_db

# Alternative: Connection string for managed DB (Supabase, etc)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ----------------------------------------------
# Docker Compose Port Mapping
# ----------------------------------------------
FRONTEND_PORT=4173
BACKEND_PORT=5000

# ----------------------------------------------
# Keycloak SSO Configuration (Optional)
# ----------------------------------------------
# Set to 'true' to enable SSO login button
KEYCLOAK_ENABLED=false

# Keycloak server settings
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=simrs
KEYCLOAK_CLIENT_ID=simrs-app
KEYCLOAK_CLIENT_SECRET=your-client-secret

# Callback URL (must match Keycloak client config)
KEYCLOAK_CALLBACK_URL=http://localhost:5000/api/auth/keycloak/callback

# Keycloak admin credentials (for docker)
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
